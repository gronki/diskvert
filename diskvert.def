Bootstrap: docker
From: debian:bullseye

%environment
    export PYTHONPATH="/source/python:${PYTHONPATH}"
    export PATH="/opt/diskvert/bin:/source/python/scripts:${PATH}"
    export LD_LIBRARY_PATH="/opt/diskvert/lib:${LD_LIBRARY_PATH}"
    export LDISKVERT_SO_PATH="/opt/diskvert/lib/libdiskvert.so"

%post
    set -e

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential gfortran python3 python3-pip \
        libopenblas-dev parallel

    apt-get clean
    rm -rf /var/lib/apt/lists/*

    mkdir -p /source

%files
    . /source

%post
    set -e

    cd /source/python
    pip3 install --no-cache-dir --no-warn-script-location -r requirements.txt

    cp -a /source/docker-scripts/*.sh /usr/bin/

    mkdir -p /source/build
    cd /source/build

    make clean
    make
    make install prefix=/opt/diskvert
    make clean

%runscript
    exec bash